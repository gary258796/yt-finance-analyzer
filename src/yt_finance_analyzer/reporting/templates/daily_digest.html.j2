<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>財經日報 — {{ trend.date }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#333;line-height:1.6;">
<div style="max-width:700px;margin:0 auto;background:#fff;padding:0;">

  {# Disclaimer #}
  <div style="background:#fff3cd;border-bottom:2px solid #ffc107;padding:12px 24px;text-align:center;font-size:13px;color:#856404;">
    &#9888;&#65039; 以下為 AI 分析整理，不構成投資建議。請獨立判斷，審慎評估風險。
  </div>

  {# Header #}
  <div style="background:#1a365d;color:#fff;padding:24px;">
    <h1 style="margin:0 0 8px;font-size:22px;font-weight:600;">&#128240; 財經日報</h1>
    <p style="margin:0;font-size:16px;opacity:0.9;">{{ trend.date }}</p>
    <p style="margin:8px 0 0;font-size:14px;opacity:0.75;">共分析 {{ trend.total_videos_analyzed }} 支影片</p>
    {# Overall sentiment #}
    <div style="margin-top:12px;">
      {% if trend.overall_sentiment == 'bullish' %}
      <span style="display:inline-block;background:#38a169;color:#fff;padding:6px 16px;border-radius:12px;font-size:14px;font-weight:600;">&#128200; 今日偏多</span>
      {% elif trend.overall_sentiment == 'bearish' %}
      <span style="display:inline-block;background:#e53e3e;color:#fff;padding:6px 16px;border-radius:12px;font-size:14px;font-weight:600;">&#128201; 今日偏空</span>
      {% elif trend.overall_sentiment == 'mixed' %}
      <span style="display:inline-block;background:#d69e2e;color:#fff;padding:6px 16px;border-radius:12px;font-size:14px;font-weight:600;">&#128256; 今日混合</span>
      {% else %}
      <span style="display:inline-block;background:#718096;color:#fff;padding:6px 16px;border-radius:12px;font-size:14px;font-weight:600;">&#9898; 今日中性</span>
      {% endif %}
    </div>
  </div>

  {# Daily narrative #}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128203; 今日概述</h2>
    <p style="margin:0;font-size:14px;color:#2d3748;">{{ trend.daily_narrative }}</p>
  </div>

  {# Sentiment breakdown #}
  {% if trend.sentiment_breakdown %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128202; 情緒分布</h2>
    <table style="width:100%;border-collapse:collapse;text-align:center;">
      <tr>
        <td style="padding:8px;">
          <div style="font-size:24px;font-weight:700;color:#38a169;">{{ trend.sentiment_breakdown.get('bullish', 0) }}</div>
          <div style="font-size:12px;color:#718096;">偏多</div>
        </td>
        <td style="padding:8px;">
          <div style="font-size:24px;font-weight:700;color:#e53e3e;">{{ trend.sentiment_breakdown.get('bearish', 0) }}</div>
          <div style="font-size:12px;color:#718096;">偏空</div>
        </td>
        <td style="padding:8px;">
          <div style="font-size:24px;font-weight:700;color:#718096;">{{ trend.sentiment_breakdown.get('neutral', 0) }}</div>
          <div style="font-size:12px;color:#718096;">中性</div>
        </td>
        <td style="padding:8px;">
          <div style="font-size:24px;font-weight:700;color:#d69e2e;">{{ trend.sentiment_breakdown.get('mixed', 0) }}</div>
          <div style="font-size:12px;color:#718096;">混合</div>
        </td>
      </tr>
    </table>
  </div>
  {% endif %}

  {# High frequency keywords #}
  {% if trend.high_frequency_keywords %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128293; 高頻關鍵字</h2>
    <div>
      {% for kw in trend.high_frequency_keywords %}
      <span style="display:inline-block;background:#ebf4ff;color:#2b6cb0;padding:4px 10px;border-radius:12px;font-size:12px;margin:0 6px 6px 0;">{{ kw }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Top industries #}
  {% if trend.top_industries %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#127981; 熱門產業</h2>
    <ol style="margin:0;padding-left:20px;font-size:14px;">
      {% for ind in trend.top_industries %}
      <li style="margin-bottom:4px;">{{ ind }}</li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  {# Top assets #}
  {% if trend.top_assets %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128176; 熱門標的</h2>
    <ol style="margin:0;padding-left:20px;font-size:14px;">
      {% for asset in trend.top_assets %}
      <li style="margin-bottom:4px;">{{ asset }}</li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  {# Recommended watchlist #}
  {% if trend.recommended_watchlist %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128270; 今日推薦追蹤</h2>
    <div>
      {% for item in trend.recommended_watchlist %}
      <span style="display:inline-block;background:#fefcbf;color:#975a16;padding:4px 10px;border-radius:12px;font-size:12px;margin:0 6px 6px 0;border:1px solid #f6e05e;">{{ item }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Strong conviction items #}
  {% if trend.strong_conviction_items %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#128170; 強烈語氣項目</h2>
    <ul style="margin:0;padding-left:20px;font-size:14px;">
      {% for item in trend.strong_conviction_items %}
      <li style="margin-bottom:6px;">{{ item }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {# Risk summary #}
  {% if trend.risk_summary %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#9888;&#65039; 風險摘要</h2>
    <div style="background:#fff5f5;border:2px solid #fc8181;border-radius:8px;padding:12px;">
      <ul style="margin:0;padding-left:16px;font-size:14px;color:#9b2c2c;">
        {% for risk in trend.risk_summary %}
        <li style="margin-bottom:6px;">{{ risk }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
  {% endif %}

  {# Video summary cards #}
  {% if analyses %}
  <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;">
    <h2 style="margin:0 0 12px;font-size:16px;color:#1a365d;">&#127909; 各影片摘要</h2>
    {% for a in analyses %}
    <div style="background:#f7f8fa;border:1px solid #e2e8f0;border-radius:8px;padding:12px;margin-bottom:10px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
        <h3 style="margin:0;font-size:14px;color:#1a365d;">
          <a href="{{ a.url }}" style="color:#1a365d;text-decoration:none;">{{ a.title }}</a>
        </h3>
      </div>
      <p style="margin:0 0 6px;font-size:12px;color:#718096;">{{ a.channel_name }} &middot; {{ a.published_at.strftime('%Y-%m-%d') }}</p>
      <p style="margin:0 0 6px;font-size:13px;color:#2d3748;">{{ a.summary_short }}</p>
      <div>
        {% if a.speaker_sentiment == 'bullish' %}
        <span style="display:inline-block;background:#c6f6d5;color:#276749;padding:2px 8px;border-radius:8px;font-size:11px;">偏多</span>
        {% elif a.speaker_sentiment == 'bearish' %}
        <span style="display:inline-block;background:#fed7d7;color:#9b2c2c;padding:2px 8px;border-radius:8px;font-size:11px;">偏空</span>
        {% elif a.speaker_sentiment == 'mixed' %}
        <span style="display:inline-block;background:#fefcbf;color:#975a16;padding:2px 8px;border-radius:8px;font-size:11px;">混合</span>
        {% else %}
        <span style="display:inline-block;background:#e2e8f0;color:#4a5568;padding:2px 8px;border-radius:8px;font-size:11px;">中性</span>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {# Footer #}
  <div style="padding:16px 24px;text-align:center;font-size:12px;color:#a0aec0;border-top:1px solid #e2e8f0;">
    <p style="margin:0;">本報告由 YT Finance Analyzer 自動產生 &middot; 僅供參考，不構成投資建議</p>
  </div>

</div>
</body>
</html>
